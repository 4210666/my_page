---
import Layout from '~/layouts/Layout.astro';
import logo from '~/assets/images/ecust-logo.png';

const metadata = {
  title: 'shorelinesky',
  description: '一个简洁、稳定、适合手机和电脑展示的首页。',
  ignoreTitleTemplate: true,
};

const highlights = [
  {
    title: '清晰展示',
    description: '首屏直接说明页面用途，不堆内容，不做复杂动效。',
  },
  {
    title: '响应式布局',
    description: '手机单列、桌面双列，自然适配不同屏幕宽度。',
  },
  {
    title: '易于扩展',
    description: '后续要加产品、文章、联系方式，都能直接往下接。',
  },
];

const sections = [
  {
    title: '适合做什么',
    items: ['个人主页', '产品首页', '项目入口', '简单介绍页'],
  },
  {
    title: '页面特点',
    items: ['内容简洁', '留白充足', '对比清楚', '移动端友好'],
  },
];
---

<Layout metadata={metadata}>
  <main class="min-h-screen bg-slate-50 text-slate-900">
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.18),_transparent_35%),radial-gradient(circle_at_bottom_left,_rgba(59,130,246,0.15),_transparent_30%)]"></div>
      <div class="absolute inset-x-0 top-0 h-px bg-slate-200/70"></div>

      <div class="relative mx-auto max-w-6xl px-6 py-6 sm:px-8 lg:px-10">
        <header class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <img src={logo.src} alt="站点标志" class="h-10 w-10 rounded-xl border border-slate-200 bg-white p-1 shadow-sm" />
            <div>
              <p class="text-sm font-medium tracking-[0.22em] text-slate-500 uppercase">shorelinesky</p>
              <p class="text-sm text-slate-500">张天硕</p>
            </div>
          </div>

          <nav class="hidden items-center gap-6 text-sm text-slate-600 md:flex" aria-label="主要导航">
            <a class="transition-colors hover:text-slate-900" href="#highlights">亮点</a>
            <a class="transition-colors hover:text-slate-900" href="#sections">内容</a>
            <a class="transition-colors hover:text-slate-900" href="#contact">联系</a>
          </nav>
        </header>

        <div class="grid items-center gap-12 py-14 lg:grid-cols-[1.15fr_0.85fr] lg:py-20">
          <div class="max-w-2xl">
            <span class="inline-flex items-center rounded-full border border-sky-200 bg-white/80 px-4 py-2 text-sm font-medium text-sky-700 shadow-sm backdrop-blur">
              简洁首页 · 手机和电脑都能正常显示
            </span>

            <h1 class="mt-6 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
              一个干净、稳定、便于继续扩展的首页。
            </h1>

            <p class="mt-5 max-w-xl text-base leading-7 text-slate-600 sm:text-lg">
              这个页面重点放在排版、间距和响应式结构上。手机上是一列，桌面上自动展开成两列和卡片区，不依赖复杂交互，也更不容易出问题。
            </p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href="#contact"
                class="inline-flex items-center justify-center rounded-full bg-slate-900 px-6 py-3 text-sm font-medium text-white shadow-lg shadow-slate-900/15 transition-transform hover:-translate-y-0.5"
              >
                继续下一步
              </a>
              <a
                href="/defense"
                class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-medium text-slate-700 transition-colors hover:border-slate-400 hover:text-slate-950"
              >
                查看原页面
              </a>
            </div>

            <dl class="mt-10 grid gap-4 sm:grid-cols-3">
              <div class="rounded-2xl border border-slate-200 bg-white/80 p-4 shadow-sm backdrop-blur">
                <dt class="text-sm text-slate-500">适配方式</dt>
                <dd class="mt-2 text-lg font-semibold text-slate-950">移动优先</dd>
              </div>
              <div class="rounded-2xl border border-slate-200 bg-white/80 p-4 shadow-sm backdrop-blur">
                <dt class="text-sm text-slate-500">视觉风格</dt>
                <dd class="mt-2 text-lg font-semibold text-slate-950">干净克制</dd>
              </div>
              <div class="rounded-2xl border border-slate-200 bg-white/80 p-4 shadow-sm backdrop-blur">
                <dt class="text-sm text-slate-500">结构</dt>
                <dd class="mt-2 text-lg font-semibold text-slate-950">单页清晰</dd>
              </div>
            </dl>
          </div>

          <div class="relative">
            <div class="absolute -inset-4 rounded-[2rem] bg-sky-200/40 blur-3xl"></div>
            <div class="relative overflow-hidden rounded-[2rem] border border-slate-200 bg-white p-6 shadow-xl shadow-slate-200/60">
              <div class="flex items-start justify-between gap-4 border-b border-slate-200 pb-5">
                <div>
                  <p class="text-sm font-medium text-slate-500">当前首页</p>
                  <h2 class="mt-1 text-2xl font-semibold text-slate-950">清晰信息区</h2>
                </div>
                <div class="rounded-full bg-emerald-50 px-3 py-1 text-sm font-medium text-emerald-700">Ready</div>
              </div>

              <div class="mt-6 grid gap-4 sm:grid-cols-2">
                {highlights.map((item) => (
                  <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                    <h3 class="text-base font-semibold text-slate-950">{item.title}</h3>
                    <p class="mt-2 text-sm leading-6 text-slate-600">{item.description}</p>
                  </article>
                ))}
              </div>

              <div class="mt-6 rounded-2xl bg-slate-950 p-5 text-white">
                <p class="text-sm text-slate-300">设计目标</p>
                <p class="mt-2 text-base leading-7">
                  页面不用华丽，但要整齐、稳定、容易看，手机和电脑打开都不会乱。
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="highlights" class="mx-auto max-w-6xl px-6 py-6 sm:px-8 lg:px-10 lg:py-8">
      <div class="grid gap-4 md:grid-cols-3">
        {highlights.map((item) => (
          <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-medium tracking-[0.2em] text-slate-500 uppercase">{item.title}</p>
            <p class="mt-4 text-base leading-7 text-slate-600">{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="sections" class="mx-auto max-w-6xl px-6 py-8 sm:px-8 lg:px-10 lg:py-12">
      <div class="grid gap-5 lg:grid-cols-2">
        {sections.map((group) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-xl font-semibold text-slate-950">{group.title}</h2>
            <ul class="mt-5 grid gap-3 sm:grid-cols-2">
              {group.items.map((item) => (
                <li class="flex items-center gap-3 rounded-2xl bg-slate-50 px-4 py-3 text-slate-700">
                  <span class="h-2.5 w-2.5 rounded-full bg-sky-500"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section id="contact" class="mx-auto max-w-6xl px-6 py-8 sm:px-8 lg:px-10 lg:py-14">
      <div class="overflow-hidden rounded-[2rem] bg-slate-900 px-6 py-10 text-white shadow-2xl shadow-slate-900/20 sm:px-10 lg:px-12">
        <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
          <div>
            <p class="text-sm font-medium tracking-[0.22em] text-slate-300 uppercase">下一步</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">如果你要正式上线，我可以继续帮你补内容。</h2>
            <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">
              可以继续做成个人主页、企业首页、产品介绍页，或者把这个首页接到你的 Cloudflare 域名上。
            </p>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
            <a
              href="mailto:hello@example.com"
              class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-medium text-slate-900 transition-transform hover:-translate-y-0.5"
            >
              邮件联系
            </a>
            <a
              href="/defense"
              class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-white/10"
            >
              备用入口
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
