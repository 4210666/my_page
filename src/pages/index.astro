<script is:inline>
// Date
const d = new Date();
document.getElementById('today-date').textContent = d.toLocaleDateString('zh-CN',{year:'numeric',month:'long',day:'numeric'});

// Scroll bar
window.addEventListener('scroll',()=>{
  const p=(window.scrollY/(document.documentElement.scrollHeight-window.innerHeight))*100;
  document.getElementById('scrollLine').style.width=p+'%';
},{passive:true});

// Section reveal
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});
},{threshold:0.07});
document.querySelectorAll('section').forEach(s=>obs.observe(s));

// Skill bars
const barObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.querySelectorAll('.skill-bar-fill').forEach(b=>{b.style.width=b.dataset.width+'%';});
      barObs.unobserve(e.target);
    }
  });
},{threshold:0.25});
const sg=document.getElementById('skillsGrid');
if(sg)barObs.observe(sg);

// Lightbox
const imgMap={
  img2:'data:image/jpeg;base64,',
  img3:'data:image/jpeg;base64,',
  img4:'data:image/jpeg;base64,',
  img5:'data:image/jpeg;base64,',
  img6:'data:image/jpeg;base64,',
  img7:'data:image/jpeg;base64,'
};
window.openLb = function openLb(key){
  document.getElementById('lbImg').src=imgMap[key];
  document.getElementById('lightbox').classList.add('open');
}
document.getElementById('lightbox').addEventListener('click',()=>{
  document.getElementById('lightbox').classList.remove('open');
});

const courseBarObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.querySelectorAll('.course-bar-fill').forEach(b=>{b.style.width=b.dataset.width+'%';});
      courseBarObs.unobserve(e.target);
    }
  });
},{threshold:0.15});
const cg=document.getElementById('courseGrid');
if(cg)courseBarObs.observe(cg);

</script>
