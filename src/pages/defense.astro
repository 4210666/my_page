    border-radius: 20px;
    padding: 1rem 0.8rem;
    text-align: center;
  }

  .info-card,
  .visual-card,
  .metric-box,
  .contribution-band {
    --card-tilt-x: 0deg;
    --card-tilt-y: 0deg;
    --card-glow-x: 50%;
    --card-glow-y: 50%;
    transform:
      perspective(1200px)
      rotateX(var(--card-tilt-x))
      rotateY(var(--card-tilt-y))
      translateY(0)
      scale(1);
    transform-style: preserve-3d;
    will-change: transform, box-shadow;
  }

  .info-card.is-hover,
  .visual-card.is-hover,
  .metric-box.is-hover,
  .contribution-band.is-hover {
    border-color: rgba(155, 213, 255, 0.34);
    background:
      radial-gradient(circle at var(--card-glow-x) var(--card-glow-y), rgba(142, 206, 255, 0.12), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0) 24%),
      linear-gradient(180deg, rgba(10, 22, 39, 0.94), rgba(6, 15, 27, 0.78));
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(136, 195, 255, 0.08),
      0 0 28px rgba(89, 162, 255, 0.12);
    transform:
      perspective(1200px)
      rotateX(var(--card-tilt-x))
      rotateY(var(--card-tilt-y))
      translateY(-6px)
      scale(1.012);
  }

