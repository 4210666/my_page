---
import { getEntry } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import logo from '~/assets/images/ecust-logo.png';
import sakuraBg from '~/assets/images/sakura-wallpaper.jpg';

const defenseEntry = await getEntry('presentation', 'defense');

if (!defenseEntry) {
  throw new Error('Presentation content entry presentation/defense not found.');
}

const defenseDeck = defenseEntry.data;

const metadata = {
  title: defenseDeck.meta.title,
  description: defenseDeck.meta.description,
  robots: { index: false, follow: false },
};

const presentationSlides = [
  { id: 'cover', label: '封面' },
  { id: 'overview', label: '结构' },
  { id: 'problem', label: '问题' },
  { id: 'theorem', label: '定理' },
  { id: 'results', label: '结果' },
  { id: 'compare', label: '价值' },
  { id: 'method', label: '路径' },
  { id: 'closing', label: '结束' },
];

const totalSlides = presentationSlides.length;
---

<Layout metadata={metadata}>
  <link slot="head" rel="stylesheet" href="/vendor/swiper/swiper-bundle.min.css" />

  <main class="presentation-app" style={`--wallpaper: url(${sakuraBg.src})`}>
    <div class="presentation-noise"></div>
    <div class="presentation-vignette"></div>
    <div class="presentation-aurora presentation-aurora-a"></div>
    <div class="presentation-aurora presentation-aurora-b"></div>

    <header class="presentation-bar">
      <div class="bar-brand">
        <p class="bar-kicker">shorelinesky</p>
        <p class="bar-title">张天硕 · Defense Deck</p>
      </div>

      <nav class="scene-tabs" aria-label="Slides">
        {presentationSlides.map((slide, index) => (
          <button class={`scene-tab ${index === 0 ? 'is-active' : ''}`} data-slide-go={index} type="button">
            <span class="scene-tab-index">{String(index + 1).padStart(2, '0')}</span>
            <span class="scene-tab-label">{slide.label}</span>
          </button>
        ))}
      </nav>

      <div class="bar-progress" aria-label="Presentation progress">
        <div class="bar-progress-topline">
          <span class="bar-progress-label">Presentation Progress</span>
          <p id="pageIndicator" class="page-indicator">01 / {String(totalSlides).padStart(2, '0')}</p>
        </div>
        <div class="progress-track"><div id="progressBar" class="progress-bar"></div></div>
      </div>

      <div class="bar-actions">
        <a class="bar-home" href="/">Home</a>
        <button id="fullscreenButton" type="button">Fullscreen</button>
      </div>
    </header>

    <section class="presentation-stage">
      <swiper-container class="presentation-swiper" init="false" a11y="true" data-total={totalSlides}>
    <swiper-slide>
      <article class="scene scene-cover" data-scene="cover">
        <div class="scene-backdrop stage-backdrop"></div>
        <div class="scene-grid cover-grid">
          <section class="stack cover-copy" data-animate-group="intro">
            <p class="eyebrow" data-animate="eyebrow">{defenseDeck.hero.eyebrow}</p>
            <h1 data-animate="title">{defenseDeck.hero.title}</h1>
            <p class="lede cover-lede" data-animate="copy">{defenseDeck.hero.subtitle}</p>

            <div class="meta-grid">
              {defenseDeck.hero.meta.map((item, index) => (
                <div class="info-card meta-card" data-animate="card" data-delay={index}>{item}</div>
              ))}
            </div>

            <div class="badge-row hero-badges" data-animate="chips">
              {defenseDeck.hero.badges.map((item) => <span class="badge hero-badge">{item}</span>)}
            </div>
          </section>

          <section class="cover-stage" data-animate-group="visual">
            <div class="visual-card orbit-panel" data-animate="visual">
              <div class="orbital-shell" data-spin="slow">
                <div class="orbital-ring orbital-ring-a"></div>
                <div class="orbital-ring orbital-ring-b"></div>
                <div class="orbital-ring orbital-ring-c"></div>
                <div class="orbital-node orbital-node-a" data-float="soft"></div>
                <div class="orbital-node orbital-node-b" data-float="wide"></div>
                <div class="orbital-node orbital-node-c" data-float="soft"></div>
              </div>
              <div class="hero-core" data-pulse="hero">
                <img src={logo.src} alt="ECUST logo" class="hero-logo" />
              </div>
              <div class="hero-signal hero-signal-a"></div>
              <div class="hero-signal hero-signal-b"></div>
            </div>

            <div class="signal-row" data-animate="support">
              <div class="info-card signal-card">
                <span class="signal-label">Structure</span>
                <strong>8 Scenes</strong>
              </div>
              <div class="info-card signal-card signal-card-warm">
                <span class="signal-label">Delivery</span>
                <strong>Stage-first</strong>
              </div>
            </div>
          </section>
        </div>
      </article>
    </swiper-slide>

    <swiper-slide>
      <article class="scene scene-overview" data-scene="overview">
        <div class="scene-backdrop grid-backdrop"></div>
        <div class="scene-head scene-head-wide" data-animate-group="intro">
          <p class="eyebrow" data-animate="eyebrow">{defenseDeck.overview.eyebrow}</p>
          <h2 data-animate="title">{defenseDeck.overview.title}</h2>
          <p class="lede" data-animate="copy">{defenseDeck.overview.subtitle}</p>
        </div>

        <div class="overview-layout">
          <div class="overview-map visual-card" data-animate="visual">
            <div class="map-line"></div>
            <div class="map-node map-node-a"><span>01</span><strong>Identity</strong></div>
            <div class="map-node map-node-b"><span>02</span><strong>Problem</strong></div>
            <div class="map-node map-node-c"><span>03</span><strong>Theorem</strong></div>
            <div class="map-node map-node-d"><span>04</span><strong>Proof</strong></div>
            <div class="map-node map-node-e"><span>05</span><strong>Results</strong></div>
          </div>

          <div class="card-grid overview-grid">
            {defenseDeck.overview.cards.map((item, index) => (
              <article class="info-card overview-card" data-animate="card" data-delay={index}>
                <span class="index-tag">0{index + 1}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="chapter-pills overview-pills" data-animate="chips">
          {defenseDeck.overview.bullets.map((item) => <span class="badge overview-pill">{item}</span>)}
        </div>
      </article>
    </swiper-slide>

    <swiper-slide>
      <article class="scene scene-problem" data-scene="problem">
        <div class="scene-backdrop problem-backdrop"></div>
        <div class="scene-grid split-grid problem-grid">
          <section class="stack" data-animate-group="intro">
            <div class="scene-head compact-head">
              <p class="eyebrow" data-animate="eyebrow">{defenseDeck.problem.eyebrow}</p>
              <h2 data-animate="title">{defenseDeck.problem.title}</h2>
              <p class="lede" data-animate="copy">{defenseDeck.problem.subtitle}</p>
            </div>

            <div class="info-card emphasis-card" data-animate="visual">
              <div class="section-glow"></div>
              <h3>为什么这一页必须先建立张力</h3>
              <ul class="bullet-list">
                {defenseDeck.problem.points.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </section>

          <section class="stack problem-aside">
            <div class="visual-card radar-panel" data-animate="visual">
              <div class="radar-ring radar-ring-a"></div>
              <div class="radar-ring radar-ring-b"></div>
              <div class="radar-grid"></div>
              <div class="radar-shape"></div>
              <div class="radar-point radar-point-a" data-pulse="soft"></div>
              <div class="radar-point radar-point-b" data-pulse="soft"></div>
              <div class="radar-point radar-point-c" data-pulse="soft"></div>
            </div>

            <div class="metric-grid problem-metrics">
              {defenseDeck.problem.metrics.map((item, index) => (
                <div class="metric-box problem-metric" data-animate="card" data-delay={index}>
                  <strong>{item.value}</strong>
                  <span>{item.label}</span>
                </div>
              ))}
            </div>
          </section>
        </div>
      </article>
    </swiper-slide>

    <swiper-slide>
      <article class="scene scene-theorem" data-scene="theorem">
        <div class="scene-backdrop theorem-backdrop"></div>
        <div class="scene-grid theorem-grid">
          <section class="visual-card theorem-stage" data-animate="visual">
            <div class="theorem-axis"></div>
            <div class="theorem-curve theorem-curve-a"></div>
            <div class="theorem-curve theorem-curve-b"></div>
            <div class="theorem-node theorem-node-a" data-pulse="soft"></div>
            <div class="theorem-node theorem-node-b" data-pulse="soft"></div>
            <div class="theorem-proof-card">
              <span>Convergence</span>
              <strong>Stable Bound</strong>
            </div>
          </section>

          <section class="stack theorem-copy">
            <div class="scene-head compact-head" data-animate-group="intro">
              <p class="eyebrow" data-animate="eyebrow">{defenseDeck.theorem.eyebrow}</p>
              <h2 data-animate="title">{defenseDeck.theorem.title}</h2>
              <p class="lede" data-animate="copy">{defenseDeck.theorem.subtitle}</p>
            </div>

            <div class="info-card theorem-card" data-animate="card">
              <h3>主定理</h3>
              <p>{defenseDeck.theorem.theorem}</p>
            </div>

            <div class="assumption-grid">
              {defenseDeck.theorem.assumptions.map((item, index) => (
                <div class="info-card assumption-card" data-animate="card" data-delay={index}>
                  <span class="index-tag">H{index + 1}</span>
                  <p>{item}</p>
                </div>
              ))}
            </div>

            <div class="badge-row theorem-takeaways" data-animate="chips">
              {defenseDeck.theorem.takeaways.map((item) => <span class="badge theorem-pill">{item}</span>)}
            </div>
          </section>
        </div>
      </article>
    </swiper-slide>
    <swiper-slide>
      <article class="scene scene-results" data-scene="results">
        <div class="scene-backdrop results-backdrop"></div>
        <div class="scene-head results-head" data-animate-group="intro">
          <p class="eyebrow" data-animate="eyebrow">{defenseDeck.results.eyebrow}</p>
          <h2 data-animate="title">{defenseDeck.results.title}</h2>
          <p class="lede" data-animate="copy">{defenseDeck.results.subtitle}</p>
        </div>

        <div class="results-layout">
          <div class="visual-card results-visual" data-animate="visual">
            <div class="results-grid"></div>
            <div class="scan-line" data-drift="scan"></div>
            <div class="beam beam-a"></div>
            <div class="beam beam-b"></div>
            <div class="beam beam-c"></div>
            <div class="heat-cluster heat-cluster-a"></div>
            <div class="heat-cluster heat-cluster-b"></div>
            <div class="chart-caption chart-caption-a">Theory</div>
            <div class="chart-caption chart-caption-b">Experiment</div>
          </div>

          <aside class="results-notes">
            {defenseDeck.results.sideNotes.map((item, index) => (
              <article class="info-card side-note" data-animate="card" data-delay={index}>
                <span class="signal-label">Focus {index + 1}</span>
                <p>{item}</p>
              </article>
            ))}
          </aside>
        </div>

        <div class="overlay-strip results-strip" data-animate="chips">
          {defenseDeck.results.bullets.map((item) => <span class="overlay-pill">{item}</span>)}
        </div>
      </article>
    </swiper-slide>

    <swiper-slide>
      <article class="scene scene-contribution" data-scene="compare">
        <div class="scene-backdrop contribution-backdrop"></div>
        <div class="scene-head scene-head-wide" data-animate-group="intro">
          <p class="eyebrow" data-animate="eyebrow">{defenseDeck.contributions.eyebrow}</p>
          <h2 data-animate="title">{defenseDeck.contributions.title}</h2>
          <p class="lede" data-animate="copy">{defenseDeck.contributions.subtitle}</p>
        </div>

        <div class="contribution-band" data-animate="support">
          <span>Problem</span>
          <span class="band-sep"></span>
          <span>Breakthrough</span>
          <span class="band-sep"></span>
          <span>Value</span>
        </div>

        <div class="card-grid contribution-grid">
          {defenseDeck.contributions.cards.map((item, index) => (
            <article class="info-card contribution-card" data-animate="card" data-delay={index}>
              <div class="card-number">0{index + 1}</div>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </article>
    </swiper-slide>

    <swiper-slide>
      <article class="scene scene-method" data-scene="method">
        <div class="scene-backdrop method-backdrop"></div>
        <div class="scene-head scene-head-wide" data-animate-group="intro">
          <p class="eyebrow" data-animate="eyebrow">{defenseDeck.method.eyebrow}</p>
          <h2 data-animate="title">{defenseDeck.method.title}</h2>
          <p class="lede" data-animate="copy">{defenseDeck.method.subtitle}</p>
        </div>

        <div class="method-layout">
          <div class="method-line" data-animate="support"></div>
          <div class="timeline-grid method-grid">
            {defenseDeck.method.steps.map((step, index) => (
              <article class="info-card timeline-card" data-animate="card" data-delay={index}>
                <span class="index-tag">0{index + 1}</span>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </article>
            ))}
          </div>
          <div class="visual-card method-console" data-animate="visual">
            <div class="console-header">
              <span></span><span></span><span></span>
            </div>
            <div class="console-line"><strong>Astro</strong><span>scene composition</span></div>
            <div class="console-line"><strong>Content</strong><span>editable structure</span></div>
            <div class="console-line"><strong>Swiper</strong><span>reliable navigation</span></div>
            <div class="console-line"><strong>GSAP</strong><span>staged motion system</span></div>
          </div>
        </div>
      </article>
    </swiper-slide>

    <swiper-slide>
      <article class="scene scene-closing" data-scene="closing">
        <div class="scene-backdrop closing-backdrop"></div>
        <div class="closing-shell">
          <div class="closing-rings" data-spin="slow">
            <div class="closing-ring closing-ring-a"></div>
            <div class="closing-ring closing-ring-b"></div>
            <div class="closing-ring closing-ring-c"></div>
          </div>
          <div class="closing-core" data-pulse="hero">
            <img src={logo.src} alt="ECUST logo" class="closing-logo" />
          </div>
        </div>

        <div class="closing-copy stack" data-animate-group="intro">
          <p class="eyebrow" data-animate="eyebrow">{defenseDeck.closing.eyebrow}</p>
          <h2 class="closing-title" data-animate="title">{defenseDeck.closing.title}</h2>
          <p class="chapter-copy" data-animate="copy">{defenseDeck.closing.quote}</p>
          <div class="chapter-pills closing-pills" data-animate="chips">
            {defenseDeck.closing.footer.map((item) => <span class="badge">{item}</span>)}
          </div>
        </div>
      </article>
    </swiper-slide>
  </swiper-container>

    </section>
  </main>

  <script is:inline src="/vendor/swiper/swiper-element-bundle.min.js"></script>
  <script is:inline src="/vendor/gsap/gsap.min.js"></script>
  <script is:inline>
    const swiperElement = document.querySelector('.presentation-swiper');
    const progressBar = document.querySelector('#progressBar');
    const pageIndicator = document.querySelector('#pageIndicator');
    const fullscreenButton = document.querySelector('#fullscreenButton');
    const slideTabs = Array.from(document.querySelectorAll('[data-slide-go]'));
    const total = Number(swiperElement?.dataset.total || 0);
    let activeSwiper = null;
    const slideTimelines = new WeakMap();
    const ambientSets = new WeakMap();
    const sheenTimers = new WeakMap();
    const sheenSelector = '.info-card, .visual-card, .metric-box, .contribution-band';
    const interactiveCardSelector = '.info-card, .visual-card, .metric-box, .contribution-band';
    const sheenProfiles = {
      cover: { baseDelay: 0.12, step: 0.18, duration: 1.95 },
      overview: { baseDelay: 0.22, step: 0.28, duration: 2.35 },
      problem: { baseDelay: 0.18, step: 0.26, duration: 2.2 },
      theorem: { baseDelay: 0.2, step: 0.3, duration: 2.45 },
      results: { baseDelay: 0.34, step: 0.44, duration: 2.9 },
      compare: { baseDelay: 0.28, step: 0.4, duration: 2.7 },
      method: { baseDelay: 0.24, step: 0.34, duration: 2.55 },
      closing: { baseDelay: 0.14, step: 0.16, duration: 1.85 },
    };

    const ensureBackdropLayers = () => {
      document.querySelectorAll('.scene-backdrop').forEach((backdrop) => {
        if (backdrop.querySelector('.ambient-orb-a')) return;

        const orbA = document.createElement('div');
        orbA.className = 'ambient-orb ambient-orb-a';

        const orbB = document.createElement('div');
        orbB.className = 'ambient-orb ambient-orb-b';

        const sweep = document.createElement('div');
        sweep.className = 'ambient-sweep-band';

        backdrop.append(orbA, orbB, sweep);
      });
    };

    const getSheenConfig = (slide, element, index) => {
      const sceneId = slide.querySelector('.scene')?.dataset.scene || 'overview';
      const profile = sheenProfiles[sceneId] || sheenProfiles.overview;
      let delay = profile.baseDelay + index * profile.step;
      let duration = profile.duration;

      if (element.classList.contains('visual-card')) {
        delay += sceneId === 'results' ? 0.16 : 0.08;
        duration += sceneId === 'results' ? 0.35 : 0.12;
      }

      if (element.classList.contains('meta-card') || element.classList.contains('signal-card')) {
        delay = 0.08 + index * 0.14;
        duration = 1.75;
      }

      if (element.classList.contains('overview-card')) {
        delay = 0.24 + index * 0.32;
        duration = 2.4;
      }

      if (element.classList.contains('problem-metric')) {
        delay = 0.52 + index * 0.26;
        duration = 2.05;
      }

      if (element.classList.contains('theorem-card')) {
        delay = 0.22;
        duration = 2.6;
      }

      if (element.classList.contains('assumption-card')) {
        delay = 0.54 + index * 0.34;
        duration = 2.4;
      }

      if (element.classList.contains('side-note')) {
        delay = 0.68 + index * 0.52;
        duration = 3.05;
      }

      if (element.classList.contains('contribution-band')) {
        delay = 0.18;
        duration = 2.2;
      }

      if (element.classList.contains('contribution-card')) {
        delay = 0.62 + index * 0.46;
        duration = 2.9;
      }

      if (element.classList.contains('timeline-card')) {
        delay = 0.46 + index * 0.36;
        duration = 2.55;
      }

      return { delay, duration };
    };

    const clearAnimations = (slide) => {
      if (!slide || !window.gsap) return;

      const timeline = slideTimelines.get(slide);
      if (timeline) {
        timeline.kill();
        slideTimelines.delete(slide);
      }

      const ambient = ambientSets.get(slide) || [];
      ambient.forEach((animation) => animation.kill());
      ambientSets.delete(slide);

      const backdrop = slide.querySelector('.scene-backdrop');
      if (backdrop && window.gsap) {
        gsap.set(backdrop.querySelectorAll('.ambient-orb, .ambient-sweep-band'), {
          clearProps: 'all',
          opacity: 0,
          xPercent: 0,
          yPercent: 0,
          scale: 1,
          rotate: 0,
        });
      }

      const sheenTimer = sheenTimers.get(slide);
      if (sheenTimer) {
        sheenTimer.kill();
        sheenTimers.delete(slide);
      }

      gsap.killTweensOf(slide.querySelectorAll('[data-animate], [data-float], [data-pulse], [data-spin], [data-drift]'));
      slide.classList.remove('sheen-active');
      slide.querySelectorAll(sheenSelector).forEach((element) => {
        element.style.removeProperty('--sheen-delay');
        element.style.removeProperty('--sheen-duration');
      });
      slide.classList.remove('is-current');
    };

    const startAmbient = (slide) => {
      const animations = [];

      const backdrop = slide.querySelector('.scene-backdrop');
      if (backdrop) {
        const orbA = backdrop.querySelector('.ambient-orb-a');
        const orbB = backdrop.querySelector('.ambient-orb-b');
        const sweep = backdrop.querySelector('.ambient-sweep-band');

        if (orbA) {
          gsap.set(orbA, { opacity: 0.42 });
          animations.push(
            gsap.to(orbA, {
              xPercent: 16,
              yPercent: -8,
              scale: 1.12,
              duration: 7.2,
              repeat: -1,
              yoyo: true,
              ease: 'sine.inOut',
            })
          );
        }

        if (orbB) {
          gsap.set(orbB, { opacity: 0.34 });
          animations.push(
            gsap.to(orbB, {
              xPercent: -14,
              yPercent: 10,
              scale: 1.08,
              duration: 8.4,
              repeat: -1,
              yoyo: true,
              ease: 'sine.inOut',
            })
          );
        }

        if (sweep) {
          gsap.set(sweep, { opacity: 0.18, xPercent: -120 });
          animations.push(
            gsap.to(sweep, {
              xPercent: 120,
              opacity: 0.58,
              duration: 5.6,
              repeat: -1,
              ease: 'none',
            })
          );
        }
      }

      slide.querySelectorAll('[data-float]').forEach((element, index) => {
        animations.push(
          gsap.to(element, {
            y: index % 2 === 0 ? -16 : 14,
            x: index % 2 === 0 ? 10 : -8,
            duration: 3.8 + index,
            repeat: -1,
            yoyo: true,
            ease: 'sine.inOut',
          })
        );
      });

      slide.querySelectorAll('[data-pulse]').forEach((element, index) => {
        animations.push(
          gsap.to(element, {
            scale: index % 2 === 0 ? 1.08 : 1.04,
            opacity: 0.9,
            duration: 1.8 + index * 0.4,
            repeat: -1,
            yoyo: true,
            ease: 'sine.inOut',
          })
        );
      });

      slide.querySelectorAll('[data-spin]').forEach((element, index) => {
        animations.push(
          gsap.to(element, {
            rotate: index % 2 === 0 ? 360 : -360,
            duration: 28 + index * 8,
            repeat: -1,
            ease: 'none',
          })
        );
      });

      slide.querySelectorAll('[data-drift]').forEach((element, index) => {
        animations.push(
          gsap.to(element, {
            xPercent: index % 2 === 0 ? 12 : -12,
            duration: 4.5 + index,
            repeat: -1,
            yoyo: true,
            ease: 'sine.inOut',
          })
        );
      });

      ambientSets.set(slide, animations);
    };

    const triggerSheen = (slide) => {
      if (!slide) return;
      slide.classList.remove('sheen-active');
      void slide.offsetWidth;
      slide.classList.add('sheen-active');
    };

    const resetCardTilt = (element) => {
      element.style.removeProperty('--card-tilt-x');
      element.style.removeProperty('--card-tilt-y');
      element.style.removeProperty('--card-glow-x');
      element.style.removeProperty('--card-glow-y');
      element.classList.remove('is-hover');
    };

    const animateSlide = (slide) => {
      if (!slide || !window.gsap) return;

      slide.classList.add('is-current');
      const sheenTargets = Array.from(slide.querySelectorAll(sheenSelector));
      const animated = slide.querySelectorAll('[data-animate]');
      const chips = slide.querySelectorAll('[data-animate="chips"] .badge, [data-animate="chips"] .overlay-pill');
      const cards = Array.from(slide.querySelectorAll('[data-animate="card"]'));
      const visuals = slide.querySelectorAll('[data-animate="visual"], [data-animate="support"]');

      sheenTargets.forEach((element, index) => {
        const { delay, duration } = getSheenConfig(slide, element, index);
        element.style.setProperty('--sheen-delay', `${delay}s`);
        element.style.setProperty('--sheen-duration', `${duration}s`);
      });

      gsap.set(animated, { clearProps: 'all' });
      gsap.set(cards, { opacity: 0, y: 34, rotateX: -10, transformOrigin: '50% 100%' });
      gsap.set(visuals, { opacity: 0, y: 20, scale: 0.96, filter: 'blur(10px)' });
      gsap.set(chips, { opacity: 0, y: 18, scale: 0.96 });
      gsap.set(slide.querySelectorAll('[data-animate="eyebrow"]'), { opacity: 0, y: 28, letterSpacing: '0.38em' });
      gsap.set(slide.querySelectorAll('[data-animate="title"]'), { opacity: 0, y: 40, filter: 'blur(18px)' });
      gsap.set(slide.querySelectorAll('[data-animate="copy"]'), { opacity: 0, y: 26 });

      const timeline = gsap.timeline({ defaults: { ease: 'power3.out' } });

      timeline
        .to(slide.querySelectorAll('[data-animate="eyebrow"]'), { opacity: 1, y: 0, letterSpacing: '0.24em', duration: 0.55 })
        .to(slide.querySelectorAll('[data-animate="title"]'), { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.8 }, '-=0.24')
        .to(slide.querySelectorAll('[data-animate="copy"]'), { opacity: 1, y: 0, duration: 0.55 }, '-=0.42')
        .to(visuals, { opacity: 1, y: 0, scale: 1, filter: 'blur(0px)', duration: 0.8, stagger: 0.08 }, '-=0.42')
        .to(
          cards,
          {
            opacity: 1,
            y: 0,
            rotateX: 0,
            duration: 0.72,
            stagger: (index, element) => 0.08 + Number(element.dataset.delay || index) * 0.04,
          },
          '-=0.54'
        )
        .to(chips, { opacity: 1, y: 0, scale: 1, duration: 0.5, stagger: 0.05 }, '-=0.44');

      const sheenTimer = gsap.delayedCall(0.78, () => triggerSheen(slide));
      sheenTimers.set(slide, sheenTimer);
      slideTimelines.set(slide, timeline);
      startAmbient(slide);
    };

    const getSwiperInstance = () => activeSwiper || swiperElement?.swiper || null;

    const updateMeta = (swiper) => {
      if (!swiper) return;

      const current = swiper.realIndex + 1;
      if (progressBar) {
        progressBar.style.width = `${(current / total) * 100}%`;
      }
      if (pageIndicator) {
        pageIndicator.textContent = `${String(current).padStart(2, '0')} / ${String(total).padStart(2, '0')}`;
      }

      slideTabs.forEach((tab, index) => {
        tab.classList.toggle('is-active', index === swiper.realIndex);
      });

      Array.from(swiper.slides || []).forEach((slide, index) => {
        if (index === swiper.realIndex) {
          clearAnimations(slide);
          animateSlide(slide);
          return;
        }

        clearAnimations(slide);
      });
    };

    const resolveSwiper = (event) => event?.detail?.[0] || event?.target?.swiper || swiperElement?.swiper;

    const bootstrapDeck = async () => {
      if (!swiperElement) return;

      ensureBackdropLayers();

      if (window.customElements?.whenDefined) {
        await customElements.whenDefined('swiper-container');
      }

      Object.assign(swiperElement, {
        slidesPerView: 1,
        speed: 920,
        spaceBetween: 12,
        keyboard: { enabled: true, onlyInViewport: true },
        mousewheel: { forceToAxis: true, releaseOnEdges: true },
        navigation: true,
        allowTouchMove: true,
        grabCursor: true,
        watchSlidesProgress: true,
        effect: 'creative',
        creativeEffect: {
          limitProgress: 2,
          perspective: true,
          prev: {
            shadow: false,
            translate: ['-10%', 0, -120],
            rotate: [0, 0, 0],
            scale: 0.94,
            opacity: 0.28,
          },
          next: {
            shadow: false,
            translate: ['10%', 0, -120],
            rotate: [0, 0, 0],
            scale: 0.94,
            opacity: 0.28,
          },
        },
      });

      const onInit = (event) => {
        activeSwiper = resolveSwiper(event) || swiperElement.swiper || activeSwiper;
        updateMeta(activeSwiper);
      };

      swiperElement.addEventListener('swiperslidechange', (event) => {
        activeSwiper = resolveSwiper(event) || swiperElement.swiper || activeSwiper;
        updateMeta(activeSwiper);
      });
      swiperElement.addEventListener('swiperinit', onInit);

      try {
        if (typeof swiperElement.initialize === 'function') {
          swiperElement.initialize();
        }
      } catch (error) {
        console.error('[defense] swiper initialize failed', error);
      }

      activeSwiper = swiperElement.swiper || activeSwiper;
      requestAnimationFrame(() => {
        activeSwiper = swiperElement.swiper || activeSwiper;
        updateMeta(activeSwiper);
      });
      window.setTimeout(() => {
        activeSwiper = swiperElement.swiper || activeSwiper;
        updateMeta(activeSwiper);
      }, 120);
    };

    bootstrapDeck().catch((error) => {
      console.error('[defense] deck bootstrap failed', error);
    });

    slideTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const index = Number(tab.dataset.slideGo || 0);
        const swiper = getSwiperInstance();
        swiper?.slideTo(index);
      });
    });

    fullscreenButton?.addEventListener('click', async () => {
      if (!document.fullscreenElement) {
        await document.documentElement.requestFullscreen();
        return;
      }

      await document.exitFullscreen();
    });

    document.querySelectorAll(interactiveCardSelector).forEach((card) => {
      card.addEventListener('pointermove', (event) => {
        const activeSlide = card.closest('.swiper-slide-active');
        if (!activeSlide) return;

        const rect = card.getBoundingClientRect();
        const px = (event.clientX - rect.left) / rect.width;
        const py = (event.clientY - rect.top) / rect.height;
        const tiltY = (px - 0.5) * 7;
        const tiltX = (0.5 - py) * 6;

        card.style.setProperty('--card-tilt-x', `${tiltX.toFixed(2)}deg`);
        card.style.setProperty('--card-tilt-y', `${tiltY.toFixed(2)}deg`);
        card.style.setProperty('--card-glow-x', `${(px * 100).toFixed(1)}%`);
        card.style.setProperty('--card-glow-y', `${(py * 100).toFixed(1)}%`);
        card.classList.add('is-hover');
      });

      card.addEventListener('pointerleave', () => resetCardTilt(card));
      card.addEventListener('pointercancel', () => resetCardTilt(card));
    });
  </script>
</Layout>

