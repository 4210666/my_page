  .info-card::before,
  .visual-card::before,
  .metric-box::before,
  .contribution-band::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.01) 18%, transparent 38%),
      linear-gradient(110deg, transparent 20%, rgba(255, 255, 255, 0.05) 36%, rgba(255, 255, 255, 0.22) 49%, rgba(134, 201, 255, 0.14) 56%, rgba(255, 255, 255, 0.05) 64%, transparent 78%);
    opacity: 0;
    transform: translate3d(-130%, 0, 0) skewX(-18deg);
    will-change: transform, opacity;
    pointer-events: none;
  }

  :global(.presentation-swiper .swiper-slide-active.sheen-active .info-card::before),
  :global(.presentation-swiper .swiper-slide-active.sheen-active .visual-card::before),
  :global(.presentation-swiper .swiper-slide-active.sheen-active .metric-box::before),
  :global(.presentation-swiper .swiper-slide-active.sheen-active .contribution-band::before) {
